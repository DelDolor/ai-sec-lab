# AI Security Lab — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── AI Gateway ─────────────────────────────────────────────────────────────────
AI_GATEWAY_HOST=0.0.0.0
AI_GATEWAY_PORT=8000
AI_GATEWAY_ENV=development

# ── Agent Runtime ───────────────────────────────────────────────────────────────
AGENT_RUNTIME_HOST=0.0.0.0
AGENT_RUNTIME_PORT=8001

# ── RAG Ingestion ───────────────────────────────────────────────────────────────
RAG_INGESTION_HOST=0.0.0.0
RAG_INGESTION_PORT=8002

# ── Qdrant (vector database) ────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ── Ollama (local LLM runtime) ──────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma:7b

# ── OpenTelemetry ───────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=ai-sec-lab
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── Security placeholders ───────────────────────────────────────────────────────
# Replace with long random strings in .env — never use these defaults in .env
SESSION_SECRET=changeme
JWT_SECRET=changeme
